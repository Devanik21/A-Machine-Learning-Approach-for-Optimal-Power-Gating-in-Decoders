* PROJECT GROUP 28 - NIT AGARTALA 2-4HP DECODER
* File Location: C:\Users\debna\Downloads\VLSI\2_4HP_Sim.net

.include 32nm_LP.pm

* --- POWER SUPPLY & INPUTS ---
Vdd Vdd 0 1.0
Va  A 0 PULSE(0 1 0 1n 1n 2n 4n)
Vb  B 0 PULSE(0 1 0 1n 1n 4n 8n)

* --- INVERTER FOR A ---
M1 A_bar A Vdd Vdd pmos L=32n W=128n
M2 A_bar A 0 0 nmos L=32n W=64n

* --- D0: CMOS NOR GATE (1.0V Standard) ---
* Implements A'B'
M3 net1 A_bar Vdd Vdd pmos L=32n W=128n
M4 D0 B net1 Vdd pmos L=32n W=128n
M5 D0 A_bar 0 0 nmos L=32n W=64n
M6 D0 B 0 0 nmos L=32n W=64n

* --- D1: TGL AND GATE (AB') ---
* B used as propagate, A as control
M7 D1 A B_bar Vdd pmos L=32n W=128n
M8 D1 A B 0 nmos L=32n W=64n
M9 D1 B_bar 0 0 nmos L=32n W=64n

* --- D2: DVL AND GATE (A'B) ---
* A used as propagate, B as control
M10 D2 B A_bar Vdd pmos L=32n W=128n
M11 D2 B A 0 nmos L=32n W=64n
M12 D2 A_bar 0 0 nmos L=32n W=64n

* --- D3: TGL AND GATE (AB) ---
* B used as propagate, A as control
M13 D3 A B Vdd pmos L=32n W=128n
M14 D3 A B_bar 0 nmos L=32n W=64n
M15 D3 B 0 0 nmos L=32n W=64n

* --- CAPACITIVE LOADS ---
C1 D0 0 0.2f
C2 D1 0 0.2f
C3 D2 0 0.2f
C4 D3 0 0.2f

* --- MEASUREMENTS ---
.tran 64n
.meas tran avg_power AVG -V(Vdd)*I(Vdd)
.meas tran max_delay_D3 TRIG V(A) VAL=0.5 RISE=1 TARG V(D3) VAL=0.5 RISE=1
.end